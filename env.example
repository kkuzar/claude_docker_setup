# Copy this file to .env and fill in your values
# cp env.example .env

# ── Required ──
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# ── GitHub ──
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# ── Optional: Auto-clone a repo on startup ──
# Used by all services except claude-local
# Format: owner/repo (no https://, no .git)
# GITHUB_REPO=your-username/your-repo
# GITHUB_BRANCH=main

# ── Local development (claude-local service only) ──
# Absolute or relative path to your local project folder
# Defaults to ./workspace if unset
# LOCAL_PATH=../my-project

# ── Commit Signing ──
# Method: "gpg", "ssh", "none", or "auto" (default: auto-detect)
# SIGNING_METHOD=auto

# Option A: GPG signing via base64-encoded private key
#   Export your key:  gpg --export-secret-keys YOUR_KEY_ID | base64 -w0 > gpg_key_b64.txt
#   Then paste the contents here:
# GPG_PRIVATE_KEY=<base64-encoded-key>
# GPG_PASSPHRASE=<your-passphrase-if-any>
# GPG_KEY_ID=<optional-override-auto-detected>

# Option B: GPG signing via mounted key file
#   Mount at runtime: -v /path/to/private.key:/home/claude/.gnupg/private.key:ro

# Option C: SSH signing via mounted key
#   Mount at runtime: -v ~/.ssh/id_ed25519:/home/claude/.ssh/signing_key:ro

# ── Optional: Headless mode ──
# CLAUDE_PROMPT=Review the codebase and fix any security issues
# CLAUDE_OUTPUT_FORMAT=text
